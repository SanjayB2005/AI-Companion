{
  "expo": {
    "name": "EmotionCompanion",
    "slug": "emotion-companion",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "dark",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.emotioncompanion.app",
      "infoPlist": {
        "NSMicrophoneUsageDescription": "This app uses the microphone for speech-to-text conversations with your companion."
      }
    },
    "android": {
      "package": "com.emotioncompanion.app",
      "softwareKeyboardLayoutMode": "pan",
      "permissions": [
        "RECORD_AUDIO"
      ]
    }
  }
}
